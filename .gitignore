# --- Environment & Secrets ---
.env
.env.*
!.env.example
*.local

# --- Dependency & Build Folders ---
node_modules/
dist/
dist-ssr/
.vercel/

# --- Logs & Debugging ---
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
Terminal Saved Output*.txt

# --- Editor & System Files ---
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db

# --- Design & Working Assets (Not for Deployment) ---
*.psd
*.ai
CHAT_LOG.md
Gemini_Generated_Image_*

# --- Root-Level Image Cleanup ---
# This ignores images in the root while allowing them in public/assets
/*.jpg
/*.jpeg
/*.png
/*.webp
/*.gif
!public/assets/

# --- Specific Backups & Originals ---
public/assets/_originals/
public/_originals/
